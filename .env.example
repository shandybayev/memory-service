# SQLite database path (use /data in Docker for persistence)
DATABASE_URL=sqlite:////data/memory.db

# Logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Max POST /turns body size in bytes (default 1 MiB)
MAX_TURN_PAYLOAD_BYTES=1048576

# Optional: enable LLM-assisted extraction (falls back to rules if unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Retrieval tuning
SEMANTIC_WEIGHT=0.45
LEXICAL_WEIGHT=0.45
RECENCY_WEIGHT=0.10
